{
  "name": "raia-mcp-server",
  "version": "0.2.0",
  "description": "Reference MCP server for RAIA Protocol — the open standard for AI agents to transact property",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "raia-mcp-server": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
