# RAIA MCP server configuration
#
# Leave RAIA_REGISTRY_BASE_URL unset to use the built-in StubRegistryAdapter.
# Set it to switch the server to RegistryHttpAdapter for live registry/private CRM data.

RAIA_REGISTRY_BASE_URL=https://registry.estateaigents.org/api/raia/v0.2
RAIA_REGISTRY_API_KEY=replace-with-registry-api-key
RAIA_AGENT_ID=org-gb-example

# RegistryHttpAdapter expects:
# POST /properties/search
# GET  /properties/{raia_id}
# GET  /agents/{raia_id}/verify
# POST /enquiries/viewings
